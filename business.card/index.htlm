<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Business Card</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <div class="business-card">
    <img 
      class="profile-image" 
      src="https://cdn.freecodecamp.org/curriculum/labs/flower.jpg" 
      alt="Profile image of a professional business card user"
    >

    <p class="full-name">zakaria abdillahi</p>
    <p class="designation">Frontend Developer</p>
    <p class="company">Creative Web Studio</p>

    <hr>

    <p>brok332920@email.com</p>
    <p>(442)-283-8951</p>

    <a 
      class="portfolio-link" 
      href="https://example.com" 
      target="_blank"
    >
      Portfolio
    </a>

    <hr>

    <div class="social-media">
      <h2>Connect with me</h2>
      <a href="https://twitter.com" target="_blank">Twitter</a><br>
      <a href="https://linkedin.com" target="_blank">LinkedIn</a><br>
      <a href="https://github.com" target="_blank">GitHub</a>
    </div>
  </div>

</body>
</html>
