body {
  background-color: rosybrown;
  font-family: Arial, sans-serif;
}

.business-card {
  width: 300px;
  background-color: #ffffff;
  padding: 20px;
  margin-top: 100px;
  margin-left: auto;
  margin-right: auto;
  text-align: center;
  font-size: 16px;
  border-radius: 10px;
}

.profile-image {
  max-width: 100%;
  border-radius: 8px;
}

p {
  margin: 5px 0;
}

a {
  text-decoration: none;
  color: #333;
}

.portfolio-link {
  display: inline-block;
  margin-top: 10px;
  font-weight: bold;
}

.social-media h2 {
  margin-bottom: 10px;
}

.social-media a {
  display: inline-block;
  margin: 3px 0;
}
